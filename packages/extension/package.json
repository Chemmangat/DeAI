{
  "name": "ai-slop-detector",
  "displayName": "AI Slop Detector",
  "description": "Flags AI-generated code patterns — obvious comments, filler names, and AI structure habits.",
  "version": "0.1.0",
  "publisher": "your-publisher-name",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "AI Slop Detector",
      "properties": {
        "aiSlopDetector.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable AI Slop Detector"
        },
        "aiSlopDetector.checkOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run checks on file save"
        },
        "aiSlopDetector.rules": {
          "type": "object",
          "default": {
            "no-obvious-comments": true,
            "no-hedge-comments": true,
            "no-divider-comments": true,
            "no-filler-suffix": true,
            "no-filler-prefix": true,
            "no-generic-names": true,
            "no-verbose-booleans": true
          },
          "description": "Enable/disable individual rules",
          "properties": {
            "no-obvious-comments": {
              "type": "boolean",
              "default": true
            },
            "no-hedge-comments": {
              "type": "boolean",
              "default": true
            },
            "no-divider-comments": {
              "type": "boolean",
              "default": true
            },
            "no-filler-suffix": {
              "type": "boolean",
              "default": true
            },
            "no-filler-prefix": {
              "type": "boolean",
              "default": true
            },
            "no-generic-names": {
              "type": "boolean",
              "default": true
            },
            "no-verbose-booleans": {
              "type": "boolean",
              "default": true
            }
          }
        },
        "aiSlopDetector.ai.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable AI-powered rename suggestions (uses built-in free service by default)"
        },
        "aiSlopDetector.ai.provider": {
          "type": "string",
          "enum": ["builtin", "openai", "anthropic", "openai-compatible"],
          "default": "builtin",
          "description": "AI provider to use. 'builtin' uses our free service, others require your own API key"
        },
        "aiSlopDetector.ai.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for the AI provider (optional for builtin, required for others)"
        },
        "aiSlopDetector.ai.model": {
          "type": "string",
          "default": "",
          "description": "Model to use (optional, uses provider default if empty)"
        },
        "aiSlopDetector.ai.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Base URL for OpenAI-compatible APIs (optional)"
        }
      }
    },
    "commands": [
      {
        "command": "aiSlopDetector.getAISuggestion",
        "title": "Get AI Suggestion for Better Name"
      }
    ]
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.19.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@ai-slop-detector/detector": "*"
  }
}
